<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Normal browser chrome -->
    <LinearLayout
        android:id="@+id/browser_chrome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/toolbar_bg"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/tv_button_background"
                android:contentDescription="@string/action_back"
                android:padding="12dp"
                android:src="@drawable/ic_back" />

            <ImageButton
                android:id="@+id/btn_forward"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/tv_button_background"
                android:contentDescription="@string/action_forward"
                android:padding="12dp"
                android:src="@drawable/ic_forward" />

            <ImageButton
                android:id="@+id/btn_reload"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/tv_button_background"
                android:contentDescription="@string/action_reload"
                android:padding="12dp"
                android:src="@drawable/ic_reload" />

            <com.tdarby.comet.ui.TvUrlBar
                android:id="@+id/url_bar"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/url_bar_bg"
                android:completionThreshold="1"
                android:dropDownHeight="wrap_content"
                android:hint="@string/url_hint"
                android:imeOptions="actionGo"
                android:importantForAutofill="no"
                android:inputType="textUri"
                android:maxLines="1"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:textColorHint="#80FFFFFF" />

            <ImageButton
                android:id="@+id/btn_go"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/tv_button_background"
                android:contentDescription="@string/action_go"
                android:padding="12dp"
                android:src="@drawable/ic_go" />

            <ImageButton
                android:id="@+id/btn_cursor"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/tv_button_background"
                android:contentDescription="@string/action_cursor"
                android:padding="12dp"
                android:src="@drawable/ic_cursor" />

            <ImageButton
                android:id="@+id/btn_voice"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/tv_button_background"
                android:contentDescription="@string/menu_voice"
                android:padding="12dp"
                android:src="@drawable/ic_mic"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btn_zoom_in"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/tv_button_background"
                android:contentDescription="@string/menu_zoom_in"
                android:padding="12dp"
                android:src="@drawable/ic_zoom_in"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btn_zoom_out"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/tv_button_background"
                android:contentDescription="@string/menu_zoom_out"
                android:padding="12dp"
                android:src="@drawable/ic_zoom_out"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/tv_button_background"
                android:contentDescription="@string/action_menu"
                android:padding="12dp"
                android:src="@drawable/ic_menu" />
        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/tab_strip_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/toolbar_bg"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/tab_strip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp" />
        </HorizontalScrollView>

        <ProgressBar
            android:id="@+id/progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="100"
            android:progress="0"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/engine_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:focusable="true"
            android:focusableInTouchMode="true" />
    </LinearLayout>

    <!-- Fullscreen video host (covers everything when active) -->
    <FrameLayout
        android:id="@+id/fullscreen_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/startup_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/ic_launcher_background"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_launcher_foreground" />

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/startup_loading"
            android:textColor="@android:color/white"
            android:textSize="20sp" />
    </LinearLayout>
</FrameLayout>
