<?xml version="1.0" encoding="utf-8"?>
<!-- No app data is backed up or transferred (matches allowBackup=false for pre-Android-12). -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
